---
interface Props {
  href: string;
  title: string;
  summary: string;
  date: Date;
  tags?: string[];
}

const { href, title, summary, date, tags = [] } = Astro.props;

const fmt = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
  timeZone: 'UTC',
});
---

<a class="card post" href={href}>
  <time class="post__date mono" datetime={date.toISOString()}>{fmt}</time>
  <h3 class="post__title">{title}</h3>
  <p class="post__summary muted">{summary}</p>
  {
    tags.length > 0 && (
      <div class="tags post__tags">
        {tags.map((t) => (
          <span class="tag">{t}</span>
        ))}
      </div>
    )
  }
</a>

<style>
  .post {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .post__date {
    font-size: 0.74rem;
    color: var(--ink-faint);
  }

  .post__title {
    margin: 0;
    font-size: 1.15rem;
  }

  .post:hover .post__title {
    color: var(--accent);
  }

  .post__summary {
    margin: 0;
    font-size: 0.93rem;
    line-height: 1.6;
  }

  .post__tags {
    margin-top: 0.5rem;
  }
</style>
